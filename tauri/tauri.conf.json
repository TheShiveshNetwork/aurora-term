{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurora",
  "version": "0.1.0",
  "identifier": "com.aurora.term",
  "build": {
    "beforeDevCommand": "pnpm --dir app dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir app build",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurora",
        "url": "index.html",
        "width": 1024,
        "height": 768,
        "minWidth": 670,
        "minHeight": 400,
        "decorations": false,
        "visible": true,
        "backgroundColor": "#0A0D14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/aurora-agent"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}